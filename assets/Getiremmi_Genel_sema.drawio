        <mxCell id="PL-6ytz9YCu_dIU6WfZg-72" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#bac8d3;strokeColor=#23445d;" value="&lt;font style=&quot;font-size: 18px;&quot;&gt;Trend &amp;amp; AI Modülleri&lt;/font&gt;" vertex="1">
