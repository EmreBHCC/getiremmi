        <mxCell id="PL-6ytz9YCu_dIU6WfZg-74" parent="1" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" value="" vertex="1">
          <mxGeometry height="170" width="293.95" x="3693.03" y="-1305.97" as="geometry" />
        </mxCell>
        <mxCell id="PL-6ytz9YCu_dIU6WfZg-77" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fillColor=#647687;strokeColor=#314354;fontColor=#ffffff;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;Bu modülün temel amacı, e-ticaret yöneticilerinin &lt;b data-path-to-node=&quot;5&quot; data-index-in-node=&quot;50&quot; style=&quot;&quot;&gt;&quot;veri kirliliği&quot;&lt;/b&gt; içinde kaybolmasını engellemektir. Farklı platformlardan gelen karmaşık fiyat, stok ve rekabet verilerini &lt;b data-path-to-node=&quot;5&quot; data-index-in-node=&quot;173&quot; style=&quot;&quot;&gt;tek bir merkezde standartlaştırarak&lt;/b&gt;, kullanıcının sadece &quot;en ucuz&quot; olana değil, &lt;b data-path-to-node=&quot;5&quot; data-index-in-node=&quot;253&quot; style=&quot;&quot;&gt;&quot;en kârlı ve en sürdürülebilir&quot;&lt;/b&gt; olana odaklanmasını sağlar.&lt;/font&gt;&lt;/h1&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;3,1,1,0,0&quot;&gt;&lt;b data-path-to-node=&quot;3,1,1,0,0&quot; data-index-in-node=&quot;0&quot;&gt;Ne yapar?&lt;/b&gt; 24+ farklı ürünü fiyat, stok ve AI puanı üzerinden kıyaslar.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;3,1,1,1,0&quot;&gt;&lt;b data-path-to-node=&quot;3,1,1,1,0&quot; data-index-in-node=&quot;0&quot;&gt;Nasıl yapar?&lt;/b&gt; Kullanıcının seçtiği ürünleri &lt;code data-path-to-node=&quot;3,1,1,1,0&quot; data-index-in-node=&quot;43&quot;&gt;React&lt;/code&gt; state&#39;inde birleştirir; veritabanından çekilen JSON verilerini dinamik bir tabloda eşleştirir.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;3,1,1,2,0&quot;&gt;&lt;b data-path-to-node=&quot;3,1,1,2,0&quot; data-index-in-node=&quot;0&quot;&gt;Neyle yapar?&lt;/b&gt; &lt;code data-path-to-node=&quot;3,1,1,2,0&quot; data-index-in-node=&quot;13&quot;&gt;React&lt;/code&gt; tablo bileşenleri ve &lt;code data-path-to-node=&quot;3,1,1,2,0&quot; data-index-in-node=&quot;40&quot;&gt;TypeScript&lt;/code&gt; tip tanımlamalarıyla hatasız kıyaslama verisi sunar.&lt;/p&gt;&lt;/li&gt;" vertex="1">
          <mxGeometry height="433.5" width="340" x="3290" y="-1226.72" as="geometry" />
        </mxCell>
        <mxCell id="PL-6ytz9YCu_dIU6WfZg-80" edge="1" parent="1" source="PL-6ytz9YCu_dIU6WfZg-72" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" target="PL-6ytz9YCu_dIU6WfZg-72">
          <mxGeometry relative="1" as="geometry" />
